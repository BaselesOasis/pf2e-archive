---
import '@picocss/pico/css/pico.min.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'PF2e Reference Archive' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — PF2e Archive</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="container">
      <nav>
        <ul>
          <li><a href="/"><strong>PF2e Archive</strong></a></li>
        </ul>
        <ul>
          <li><a href="/spells">Spells</a></li>
          <li><a href="/feats">Feats</a></li>
          <li><a href="/equipment">Equipment</a></li>
          <li><a href="/ancestries">Ancestries</a></li>
          <li><a href="/classes">Classes</a></li>
          <li><a href="/backgrounds">Backgrounds</a></li>
          <li><a href="/conditions">Conditions</a></li>
          <li><a href="/search">Search</a></li>
        </ul>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="container">
      <small>
        Built with Astro, Pico CSS, and Pagefind. Data from the
        <a href="https://github.com/foundryvtt/pf2e" target="_blank" rel="noopener">Foundry VTT PF2e system</a>.
      </small>
    </footer>
  </body>
</html>
