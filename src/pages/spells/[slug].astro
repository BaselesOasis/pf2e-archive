
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import spells from '../../data/spells.json';

export async function getStaticPaths() {
  return spells.map(spell => ({
    params: { slug: spell.slug },
    props: { spell }
  }));
}

const { spell } = Astro.props;
---

<BaseLayout title={spell.name} description={spell.description.substring(0, 160).replace(/<[^>]*>/g, '')}>
  <article>
    <header>
      <h1>{spell.name}</h1>
      <p>
        <small>
          {spell.rarity !== 'common' && <mark>{spell.rarity}</mark>}
          {spell.rarity !== 'common' && ' · '}
          Rank {spell.level ?? '—'}
        </small>
      </p>
    </header>

    <p>
      {spell.traits.map(trait => (
        <small><mark>{trait}</mark></small>
      ))}
    </p>

    <table>
      <tbody>
        <tr>
          <th>Cast</th>
          <td>{spell.castTime ? `${spell.castTime} actions` : '—'}</td>
        </tr>
        <tr>
          <th>Range</th>
          <td>{spell.range ?? '—'}</td>
        </tr>
        <tr>
          <th>Area</th>
          <td>{spell.area ?? '—'}</td>
        </tr>
        <tr>
          <th>Duration</th>
          <td>{spell.duration ?? '—'}</td>
        </tr>
        <tr>
          <th>Defense</th>
          <td>{spell.defense ?? '—'}</td>
        </tr>
        <tr>
          <th>Traditions</th>
          <td>{spell.traditions?.join(', ') ?? '—'}</td>
        </tr>
      </tbody>
    </table>

    <h2>Description</h2>
    <div set:html={spell.description} />

    {spell.publication && (
      <footer>
        <small>
          Source: {spell.publication.title} ({spell.publication.license})
        </small>
      </footer>
    )}

    <hr />
    <p><a href="/spells">← Back to Spells</a></p>
  </article>
</BaseLayout>
